# ============================================================
# نمونه فایل متغیرهای محیطی برای IGDB Complete Scraper
# این فایل را کپی کرده و به .env تغییر نام دهید
# سپس مقادیر واقعی را جایگزین کنید
# ============================================================

# کلیدهای API توئیچ (برای دسترسی به IGDB)
# دریافت از: https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# ============================================================
# نکات مهم:
# 1. هرگز فایل .env واقعی را به گیت‌هاب commit نکنید!
# 2. فقط فایل .env.example را commit کنید
# 3. در GitHub Actions، این مقادیر را در Secrets قرار دهید
# ============================================================
